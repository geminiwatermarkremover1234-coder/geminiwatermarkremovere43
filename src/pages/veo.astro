        </div>
    </section>

    <!-- ==================== WORKSPACE PANEL ==================== -->
    <section class="px-margin-mobile md:px-gutter max-w-container-max mx-auto pb-12">
        <div class="bg-surface-container-lowest rounded-[32px] border border-outline-variant/30 shadow-xl p-6 md:p-8 max-w-4xl mx-auto mb-8 relative">
