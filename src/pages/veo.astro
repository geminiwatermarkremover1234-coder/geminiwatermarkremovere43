                <span class="material-symbols-outlined text-primary text-[18px]">movie</span>
                <span>Veo Video Cleaner Studio</span>
            </div>

            <!-- Drag & Dropzone -->
            <div class="w-full min-h-[260px] border-2 border-dashed border-outline-variant/40 rounded-2xl flex flex-col items-center justify-center p-8 cursor-pointer transition-all hover:border-primary/50 hover:bg-primary/[0.02]" id="veo-drop">
                <span class="material-symbols-outlined text-on-surface-variant/40 text-5xl mb-4 transition-all">cloud_upload</span>
                <h3 class="text-lg md:text-xl font-display font-bold text-on-background mb-2">Drop your Veo MP4s here or click to browse</h3>
                <p class="text-body-md text-on-surface-variant text-center">Up to 20 videos at a time · 720p, 1080p, or 4K</p>
                <p class="text-label-sm text-on-surface-variant/60 text-center mt-2">Landscape 16:9 or portrait 9:16</p>
            </div>
            <input type="file" id="veo-file" accept="video/mp4,video/*" multiple class="hidden">

            <!-- Original files warning note -->
            <div class="flex gap-3 items-start bg-primary/5 border border-primary/10 rounded-xl p-4 text-body-md text-on-surface-variant mt-6 mb-6">
                <span class="material-symbols-outlined text-primary text-[20px] flex-shrink-0 mt-0.5">info</span>
                <p class="text-label-sm leading-relaxed text-on-surface-variant"><strong>Original files only.</strong> Upload the MP4 downloaded directly from Veo / Flow (labs.google). Videos re-encoded by WhatsApp, Telegram, or social media lose the watermark signature and cannot be cleaned.</p>
            </div>

            <!-- Agreement Box -->
            <div class="flex items-start gap-3 mb-6">
                <input type="checkbox" id="veo-agree" checked class="mt-1 w-4 h-4 text-primary bg-surface border-outline-variant rounded focus:ring-primary focus:ring-2">
                <label for="veo-agree" class="text-label-sm text-on-surface-variant leading-relaxed select-none">I own this media or have permission to edit it. I will not remove third-party copyright marks or creator credits.</label>
            </div>

            <!-- Queue list and summary -->
            <div class="flex flex-col gap-3 mb-4 max-h-[240px] overflow-y-auto" id="veo-queue" style="display: none;"></div>
            <div class="text-label-sm text-on-surface-variant font-medium mb-6" id="veo-queue-summary" style="display: none;"></div>

            <!-- Process buttons controls row -->
            <div class="flex items-center gap-3 flex-wrap mt-6">
                <button class="bg-primary hover:bg-primary-container text-on-primary font-body font-semibold text-label-md px-6 py-3 rounded-xl active:scale-95 transition-all shadow-md disabled:opacity-40 disabled:pointer-events-none" id="veo-process" disabled>Remove Veo Watermark</button>
                <button class="bg-primary hover:bg-primary-container text-on-primary font-body font-semibold text-label-md px-6 py-3 rounded-xl active:scale-95 transition-all shadow-md" id="veo-process-all" style="display:none">Remove From All</button>
                <button class="bg-surface border border-outline-variant/30 hover:border-primary/50 text-on-surface-variant hover:text-primary font-body font-semibold text-label-md px-6 py-3 rounded-xl active:scale-95 transition-all shadow-sm" id="veo-download" style="display:none">Download Cleaned MP4</button>
                <button class="bg-surface border border-outline-variant/30 hover:border-primary/50 text-on-surface-variant hover:text-primary font-body font-semibold text-label-md px-6 py-3 rounded-xl active:scale-95 transition-all shadow-sm" id="veo-download-all" style="display:none">Download All</button>
                <button class="bg-surface border border-outline-variant/30 hover:border-error/50 text-on-surface-variant hover:text-error font-body font-semibold text-label-md px-6 py-3 rounded-xl active:scale-95 transition-all shadow-sm" id="veo-reset" style="display:none">Start Over</button>
                <span class="text-label-sm text-on-surface-variant font-medium ml-auto" id="veo-meta"></span>
            </div>

            <!-- Progress Box -->
            <div class="mt-6" id="veo-progress" style="display: none;">
                <div class="flex justify-between items-center text-label-sm text-on-surface-variant mb-2">
                    <span id="veo-stage">Processing</span>
                    <span id="veo-pct" class="font-bold">0%</span>
