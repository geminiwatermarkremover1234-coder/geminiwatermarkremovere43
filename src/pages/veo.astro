    <style is:global>
        .glass-panel { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.2); }
        .gradient-text { background: linear-gradient(135deg, #4648d4 0%, #00687a 50%, #4648d4 100%); background-size: 200% auto; -webkit-background-clip: text; -webkit-text-fill-color: transparent; animation: shimmer 4s ease-in-out infinite; }
        .mobile-nav-open { overflow: hidden; }
        #mobile-menu { transition: transform 0.3s ease-in-out; transform: translateX(100%); }
        #mobile-menu.active { transform: translateX(0); }
        
        /* ====== HERO & BACKGROUND ANIMATIONS ====== */
        @keyframes float {
            0%, 100% { transform: translateY(0px) scale(1); }
            50% { transform: translateY(-20px) scale(1.05); }
        }
        @keyframes floatReverse {
            0%, 100% { transform: translateY(0px) scale(1) rotate(0deg); }
            50% { transform: translateY(15px) scale(0.95) rotate(5deg); }
        }
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        @keyframes shimmer {
            0% { background-position: 0% center; }
            50% { background-position: 100% center; }
            100% { background-position: 0% center; }
        }
        @keyframes pulseGlow {
            0%, 100% { box-shadow: 0 0 20px rgba(70, 72, 212, 0.15); }
            50% { box-shadow: 0 0 40px rgba(70, 72, 212, 0.3), 0 0 60px rgba(70, 72, 212, 0.1); }
        }
        .hero-orb {
            position: absolute;
            border-radius: 50%;
            filter: blur(80px);
            pointer-events: none;
            will-change: transform;
            z-index: 0;
        }
        .hero-orb-1 {
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(70, 72, 212, 0.2), transparent 70%);
            top: -80px; right: -60px;
            animation: float 8s ease-in-out infinite;
        }
        .hero-orb-2 {
            width: 300px; height: 300px;
            background: radial-gradient(circle, rgba(0, 104, 122, 0.15), transparent 70%);
            top: 40%; left: -80px;
            animation: floatReverse 10s ease-in-out infinite;
        }
        .hero-orb-3 {
            width: 200px; height: 200px;
            background: radial-gradient(circle, rgba(96, 99, 238, 0.12), transparent 70%);
            bottom: -40px; right: 20%;
            animation: float 12s ease-in-out 2s infinite;
        }
        .hero-particle {
            position: absolute;
            width: 4px; height: 4px;
            background: rgba(70, 72, 212, 0.4);
            border-radius: 50%;
            pointer-events: none;
        }
        .hero-particle:nth-child(4) { top: 15%; left: 10%; animation: float 6s ease-in-out infinite; }
        .hero-particle:nth-child(5) { top: 25%; right: 15%; animation: floatReverse 8s ease-in-out 1s infinite; }
        .hero-particle:nth-child(6) { bottom: 20%; left: 25%; animation: float 7s ease-in-out 0.5s infinite; }
        
        .hero-glass-card {
            background: rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(70, 72, 212, 0.12);
            border-radius: 2rem;
            padding: 2.5rem 2rem;
            animation: pulseGlow 6s ease-in-out infinite;
            position: relative;
            overflow: hidden;
        }
        .hero-glass-card::before {
            content: '';
            position: absolute;
            top: 0; left: -100%;
            width: 200%; height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.03), transparent);
            animation: shimmer 6s ease-in-out infinite;
        }
        .hero-badge { animation: fadeSlideUp 0.6s ease-out both; }
        .hero-title { animation: fadeSlideUp 0.8s ease-out 0.15s both; }
        .hero-desc { animation: fadeSlideUp 0.8s ease-out 0.3s both; }

        /* ====== MATCHED VIDEO SIZING ====== */
        .video-matched-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 1.5rem;
            width: 100%;
        }
        @media (min-width: 768px) {
            .video-matched-grid {
                grid-template-columns: 1fr 1fr;
            }
        }
        .video-matched-grid.portrait {
            grid-template-columns: repeat(2, minmax(0, 320px));
            justify-content: center;
        }
        @media (max-width: 640px) {
            .video-matched-grid.portrait {
                grid-template-columns: 1fr;
            }
        }
        .video-matched-grid .video-container {
            display: flex;
            flex-direction: column;
        }
        .video-matched-grid video {
            width: 100%;
            aspect-ratio: 16/9;
            object-fit: contain;
            background: #1a1a2e;
            border-radius: 0.75rem;
            border: 1px solid rgba(70, 72, 212, 0.15);
        }
        .video-matched-grid.portrait video {
            aspect-ratio: 9/16;
        }

        /* ====== QUEUE ITEM STYLING ====== */
        .queue-item {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.75rem 1rem;
            border-radius: 0.75rem;
            border: 1px solid rgba(0, 0, 0, 0.08);
            background: #ffffff;
            transition: all 0.2s ease;
            text-align: left;
        }
        .queue-item:hover {
            border-color: rgba(70, 72, 212, 0.3);
            background: rgba(70, 72, 212, 0.02);
        }
        .queue-item.active {
            border-color: #4648d4;
            background: rgba(70, 72, 212, 0.05);
            box-shadow: 0 4px 12px rgba(70, 72, 212, 0.05);
        }
        .queue-details {
            display: flex;
            flex-direction: column;
            min-width: 0;
            flex: 1;
        }
        .queue-name {
            font-size: 0.875rem;
            font-weight: 600;
            color: #191c1e;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .queue-state {
            font-size: 0.75rem;
            color: #464554;
            margin-top: 0.125rem;
        }
        .queue-item.active .queue-state {
            font-weight: 500;
        }
        .queue-state.st-processing { color: #4648d4; font-weight: 700; }
        .queue-state.st-done { color: #16a34a; font-weight: 700; }
        .queue-state.st-error { color: #ba1a1a; font-weight: 700; }
        
        .queue-icon-btn {
            background: transparent;
            border: none;
            color: #767586;
            cursor: pointer;
            padding: 0.375rem;
            border-radius: 0.5rem;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 14px;
        }
        .queue-icon-btn:hover {
            color: #4648d4;
            background: rgba(70, 72, 212, 0.08);
        }
        .queue-icon-btn.rm:hover {
            color: #ba1a1a;
            background: rgba(186, 26, 26, 0.1);
        }
    </style>
</head>
